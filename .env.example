# ─── Magazyn danych (Lab 7) ──────────────────────────────────────────
# "local"     — wszystko w localStorage (domyślnie)
# "firestore" — Google Cloud Firestore (NoSQL)
VITE_STORAGE_MODE=local

# ─── Google OAuth (Lab 6) ────────────────────────────────────────────
# Client ID z Google Cloud Console (OAuth 2.0 Web application).
# Gdy pusty, aplikacja działa w trybie dev (logowanie po e-mailu).
VITE_GOOGLE_CLIENT_ID=

# ─── Firebase / Firestore (Lab 7) ────────────────────────────────────
# Wymagane tylko gdy VITE_STORAGE_MODE=firestore.
# Wartości weź z Firebase Console → Project settings → Your apps.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
